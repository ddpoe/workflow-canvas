# Minimal image for the Tier 3 integration smoke tests.
#
# A plain Python image with NOTHING wfc-related installed — the living proof
# of the thin-container dispatch contract: `wfc run-step` executes the method
# script directly under the env's recorded interpreter, so a registered env
# image needs only the interpreter and whatever the method itself imports.
# The Tier-2 methods used against this image are stdlib-only.
FROM python:3.11-slim

WORKDIR /work
