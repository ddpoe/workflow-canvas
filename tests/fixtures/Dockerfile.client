# Tier-1 user-env image for ADR-020 integration tests.
#
# Installs ONLY the pure-stdlib `wfc-client` package so a Tier-1 user method
# can `import wfc_client as wfc` and call `@wfc.method` / `ctx.save_artifact`.
# The full `wfc` engine is deliberately absent: under thin-container dispatch
# the host `wfc run-step` runs the method script directly via the env's
# interpreter, so the image needs nothing wfc-engine-related.
#
# This image represents a real user environment that has opted into the Tier-1
# authoring sugar. The Tier-2 parity test deliberately uses Dockerfile.minimal
# (NO wfc-client) so the equivalent method runs against env-vars + files only.
FROM python:3.11-slim

WORKDIR /build

# Copy the standalone wfc-client package (nested poetry package at
# wfc-client/ since the 0.1.0 PyPI restructure) and install it (zero deps).
COPY wfc-client ./wfc-client
RUN pip install ./wfc-client

WORKDIR /work
